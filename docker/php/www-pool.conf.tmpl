; php-fpm プール設定（entrypoint が env から envsubst で生成）。
; 既定 www.conf の [www] を後勝ちで上書きする（listen 等は既定を継承）。
;
; ── pm.max_children の目安 ──
;   max_children ≒ (割り当てメモリ - 予約) / 1プロセスの実測メモリ
;   例: 4GB を PHP に割り当て、1プロセス ~80MB なら 40〜50 前後。
;   まず控えめに設定し、`docker compose logs` や実測で調整する。
[www]
pm = ${PHP_FPM_PM}
pm.max_children = ${PHP_FPM_MAX_CHILDREN}
pm.start_servers = ${PHP_FPM_START_SERVERS}
pm.min_spare_servers = ${PHP_FPM_MIN_SPARE}
pm.max_spare_servers = ${PHP_FPM_MAX_SPARE}
; リクエストを捌くごとにワーカーを再生成し、メモリリークを防ぐ
pm.max_requests = ${PHP_FPM_MAX_REQUESTS}
; ワーカーの stdout/stderr をコンテナログへ
catch_workers_output = yes
decorate_workers_output = no
; 死活・飽和の可観測性。healthcheck が /fpm-ping を叩く。
; /fpm-status は active/idle プロセス数・listen queue を返す（外部公開はしない）。
pm.status_path = /fpm-status
ping.path = /fpm-ping
ping.response = pong
