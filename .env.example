# ========================================================================
# EC-CUBE Docker 汎用環境 設定サンプル
#   cp .env.example .env して編集する（.env は .gitignore 済み）。
#   bin/init.sh を使うと .env 作成と ECCUBE_AUTH_MAGIC 生成まで自動で行う。
# ========================================================================

# ---- EC-CUBE 本体 ----
# composer create-project のバージョン制約。切替は bin/switch-version.sh を使う。
#   4.3系: ~4.3.0  /  4.2系: ~4.2.0  /  4.1系: ~4.1.0
ECCUBE_VERSION=~4.3.0
PHP_VERSION=8.2

# 実行モード。既定は本番。開発でデバッグしたいときだけ dev / 1 にする。
APP_ENV=prod
APP_DEBUG=0
ECCUBE_LOCALE=ja
ECCUBE_ADMIN_ROUTE=admin

# アプリのシークレット。空のままだと bin/console が落ちる。
# bin/init.sh が未設定/プレースホルダなら自動生成する（openssl rand -hex 16）。
# 手動なら: openssl rand -hex 16 の値を入れる。本番では必ず固有の値にすること。
ECCUBE_AUTH_MAGIC=change_this_to_a_random_hex_string

# ---- データベース ----
DB_NAME=eccube_db
DB_USER=eccube
DB_PASSWORD=eccube_pass
DB_ROOT_PASSWORD=change_me_root
DATABASE_SERVER_VERSION=mariadb-10.6.0

# ---- メール ----
# 開発は未設定でよい（compose.override.yaml が自動で Mailpit 宛てにする）。
# 本番は実メールサービスの DSN を設定する。未設定なら送信は破棄される（null://null）。
#   例: MAILER_DSN=smtp://user:pass@smtp.example.com:587
#MAILER_DSN=

# ---- 開発時のポート ----
HTTP_PORT=8080
MAILPIT_UI_PORT=8025
PMA_PORT=8081

# ---- パフォーマンス / スケール（Tier 1）----
# php-fpm ワーカー数。サーバーの CPU/メモリに合わせて調整する。
#   max_children ≒ (PHP に割り当てるメモリ) / (1プロセスの実測メモリ ~80MB)
PHP_FPM_PM=dynamic
PHP_FPM_MAX_CHILDREN=20
PHP_FPM_START_SERVERS=4
PHP_FPM_MIN_SPARE=2
PHP_FPM_MAX_SPARE=6
PHP_FPM_MAX_REQUESTS=500
# Symfony アプリキャッシュの Redis 共有。既定はローカルの redis サービス。
# 本番でマネージド Redis を使うなら redis://user:pass@host:6379 の形で上書き。
REDIS_URL=redis://redis:6379
REDIS_MAXMEMORY=256mb
# セッション保存用 Redis（Tier 2: 複数ホストでセッション共有）。キャッシュ用とは別。
# 本番でマネージド Redis を使うなら上書きする。
SESSION_REDIS_URL=redis://redis-session:6379
# ※ MariaDB の innodb_buffer_pool_size 等は docker/mariadb/conf.d/eccube.cnf で調整。
#    OPcache は APP_ENV=prod のとき entrypoint が validate_timestamps=0 に切替える。

# ========================================================================
# 本番公開（compose.prod.yaml を使うとき）
#   次行を有効化すると docker compose の -f を省略できる:
# COMPOSE_FILE=compose.yaml:compose.prod.yaml
#
# 公開方式を選ぶ（tunnel / caddy / 空=背後配置）:
# ========================================================================
COMPOSE_PROFILES=tunnel

# tunnel 用: Cloudflare Zero Trust で発行したトークン
#TUNNEL_TOKEN=

# caddy 用: 公開ドメイン（A レコードをこのサーバーへ向ける）
#SITE_DOMAIN=shop.example.com
