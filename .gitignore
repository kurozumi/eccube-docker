# 環境ごとの秘密・生成物
/.env
/.env.bak

# Claude Code の個人設定（共有しない。共有は .claude/settings.json）
/.claude/settings.local.json

# EC-CUBE 本体はイメージにベイクするので、このリポジトリには持たない。
# app/ 配下（Customize / template / DoctrineMigrations / config）は
# あなたの成果物なので Git 管理する。
/var/

# フロントビルドの依存（生成物）。scss ソースと成果物 css は Git 管理する。
/frontend/node_modules/
/html/user_data/assets/css/*.map
/backups/
